<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Repo-Übersicht (WR-82/83): freie Beschreibung + Sichtbarkeits-/Typ-Badge. Additiv. -->
    <changeSet id="0011-source-description-visibility" author="scanner">
        <addColumn tableName="repository_source">
            <column name="description" type="VARCHAR(1024)"/>
            <column name="visibility" type="VARCHAR(32)" defaultValue="private"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
