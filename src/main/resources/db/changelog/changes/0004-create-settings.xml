<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Systemweite Einstellungen als Singleton-Zeile (WR-15..18). -->
    <changeSet id="0004-settings" author="scanner">
        <createTable tableName="settings">
            <column name="id" type="BIGINT"><constraints primaryKey="true" nullable="false"/></column>
            <column name="general_notification_email" type="VARCHAR(512)"/>
            <column name="default_fail_on" type="VARCHAR(16)"><constraints nullable="false"/></column>
            <column name="default_scan_mode" type="VARCHAR(32)"><constraints nullable="false"/></column>
            <column name="retention_days" type="INT"><constraints nullable="false"/></column>
            <column name="secret_refs" type="VARCHAR(2048)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
