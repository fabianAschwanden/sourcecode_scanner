<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- UI-verwaltete Secrets (WR-17/19). reference = env:/vault:-Verweis; encrypted_value =
         AES-GCM-Chiffrat (Modus DB_ENCRYPTED, NFR-29) — NIE Klartext. -->
    <changeSet id="0010-create-managed-secret" author="scanner">
        <createTable tableName="managed_secret">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="mode" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="reference" type="VARCHAR(512)"/>
            <column name="encrypted_value" type="VARCHAR(8192)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
