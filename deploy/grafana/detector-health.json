{
  "__comment": "Grafana-Dashboard Detector Health (OR-06): Laufzeit und Fehlerrate je Detektor. Datenquelle Prometheus (/q/metrics).",
  "title": "Scanner — Detector Health",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "timeseries",
      "title": "Detektor-Laufzeit p95 (s)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, detector) (rate(scanner_detector_duration_seconds_bucket[5m])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Detektor-Fehler/Degradationen je Detektor",
      "targets": [{ "expr": "sum by (detector) (rate(scanner_detector_errors_total[15m]))" }]
    },
    {
      "type": "stat",
      "title": "Aktive Detektoren (mit Aktivität)",
      "targets": [{ "expr": "count(count by (detector) (scanner_detector_duration_seconds_count))" }]
    }
  ]
}
